<?xml version="1.0" encoding="UTF-8"?>
<xs:schema 
	xmlns:xs="http://www.w3.org/2001/XMLSchema" 
	xmlns:t="http://www.gep.msess.gov.pt/sguri/tipos_comuns" 
	xmlns="http://www.gep.msess.gov.pt/sguri/ru/anexo_sst" targetNamespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_sst" elementFormDefault="qualified" version="2.3.14">
	<xs:import namespace="http://www.gep.msess.gov.pt/sguri/tipos_comuns" schemaLocation="tipos-comuns-1.3.14.xsd" />
	<xs:element name="anexo_sst" type="anexo_sstType">
		<xs:annotation>
			<xs:documentation>ANEXO D - RELATÓRIO ANUAL DE ACTIVIDADE DO SERVIÇO DE SEGURANÇA E SAÚDE NO TRABALHO </xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="anexo_sstType">
		<xs:sequence>
			<xs:element name="nome_entidade" type="t:max70Type">
				<xs:annotation>
					<xs:documentation>I - Nome ou Designação social</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="estabs">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="estab" minOccurs="0" maxOccurs="unbounded">
							<xs:complexType>
								<xs:sequence>
									<!-- I - UNIDADE LOCAL (ESTABELECIMENTO) -->
									<xs:element name="exist_trab_serv" type="t:choiceType">
										<xs:annotation>
											<xs:documentation>I - 1. Existiram trabalhadores ao serviço em algum período de referência do relatório? </xs:documentation>
										</xs:annotation>
									</xs:element>
									<xs:element name="dados_sst" minOccurs="0">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="cae_31Dez" type="t:caeType">
													<xs:annotation>
														<xs:documentation>I - 2. Actividade económica principal (CAE) da unidade local em 31 de Dezembro. </xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="n_medio_trab">
													<xs:annotation>
														<xs:documentation>I - 3. Número médio de trabalhadores afectos à unidade local (estabelecimento), no ano. </xs:documentation>
													</xs:annotation>
													<xs:complexType>
														<xs:sequence>
															<xs:element name="vinc" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.1 Vinculados por contrato de trabalho ou equiparado ao empregador responsável pelo relatório (3.1.1 + 3.1.2). </xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="total" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Total. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="h" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Homens. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="m" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Mulheres. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="vinc_a_trab" type="n_medio_trabType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.1.1 A trabalhar na unidade local (estabelecimento). </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="vinc_trab_fora" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.1.2 A trabalhar fora da unidade local (estabelecimento) (3.1.2.1 + 3.1.2.2 + 3.1.2.3). </xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="total" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Total. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="h" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Homens. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="m" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Mulheres. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="vinc_trab_fora_temp" type="n_medio_trabType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.1.2.1 Trabalhadores temporários cedidos por contrato de utilização. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="vinc_trab_fora_ocas" type="n_medio_trabType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.1.2.2 Trabalhadores em regime de cedência ocasional. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="vinc_trab_fora_outros" type="n_medio_trabType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.1.2.3 Outros trabalhadores (em regime de teletrabalho ou trabalhadores no domicílio). </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="outros" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.2 Outros trabalhadores a trabalhar na unidade local (estabelecimento) (3.2.1 + 3.2.2 + 3.2.3). </xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="total" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Total. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="h" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Homens. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="m" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Mulheres. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="outros_ced" type="n_medio_trabType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.2.1 Trabalhadores temporários cedidos por contrato de utilização. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="outros_ind" type="n_medio_trabType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.2.2 Trabalhadores independentes e trabalhadores ao serviço de empresas prestadoras de serviços. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="outros_ocas" type="n_medio_trabType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>I - 3.2.3 Trabalhadores em regime de cedência ocasional. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="total">
																<xs:annotation>
																	<xs:documentation>I - 3.3 TOTAL (3.1 + 3.2) </xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="total" type="t:num7Type">
																			<xs:annotation>
																				<xs:documentation>Total. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="h" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Homens. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																		<xs:element name="m" type="t:num6Type" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>Mulheres. </xs:documentation>
																			</xs:annotation>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
														</xs:sequence>
													</xs:complexType>
												</xs:element>
												<xs:element name="n_total_efec" type="t:num9Type" minOccurs="0">
													<xs:annotation>
														<xs:documentation>I - 4. Número total de horas efectivamente trablhadas (incluindo as suplementares) durante o ano, pelos trabalhadores declarados em 3.1.1. </xs:documentation>
													</xs:annotation>
												</xs:element>
												<!-- II - NATUREZA DA MODALIDADE ADOPTADA NA ORGANIZAÇÃO DOS SERVIÇOS DE SEGURANÇA E SAÚDE NO TRABALHO. -->
												<xs:element name="organi_serv_seg" type="t:choiceType">
													<xs:annotation>
														<xs:documentation>II - 1. Foram organizados os serviços de segurança no trabalho? </xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="organi_serv_saude" type="t:choiceType">
													<xs:annotation>
														<xs:documentation>II - 2. Foram organizados os serviços de saúde no trabalho? </xs:documentation>
													</xs:annotation>
												</xs:element>
												<xs:element name="servicos_sst" minOccurs="0">
													<xs:complexType>
														<xs:sequence>
															<xs:element name="n_trab_afect" type="t:num3Type">
																<xs:annotation>
																	<xs:documentation>II - 3. Quantos trabalhadores estão afectos à organização da estrutura interna de 1ºs socorros, combate a incêndios e evacuação de instalações? </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="org_no_estab" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>II - 4. As actividades de segurança e saúde no trabalho foram organizadas. </xs:documentation>
																</xs:annotation>
																<xs:simpleType>
																	<xs:restriction base="xs:string">
																		<xs:enumeration value="C">
																			<xs:annotation>
																				<xs:documentation>Em conjunto. </xs:documentation>
																			</xs:annotation>
																		</xs:enumeration>
																		<xs:enumeration value="S">
																			<xs:annotation>
																				<xs:documentation>Em separado. </xs:documentation>
																			</xs:annotation>
																		</xs:enumeration>
																	</xs:restriction>
																</xs:simpleType>
															</xs:element>
															<xs:element name="modalidade">
																<xs:annotation>
																	<xs:documentation>II - 5. Especifique a modalidade. </xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="seguranca" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>II - 5.1 No domínio da segurança. </xs:documentation>
																			</xs:annotation>
																			<xs:complexType>
																				<xs:sequence>
																					<xs:element name="serv_internos" type="t:choiceType">
																						<xs:annotation>
																							<xs:documentation>II - 5.1.1 Serviço interno (SI). </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="serv_part" type="t:choiceType">
																						<xs:annotation>
																							<xs:documentation>II - 5.1.2 Serviço comum (SCP). </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="serv_ext" type="t:choiceType">
																						<xs:annotation>
																							<xs:documentation>II - 5.1.3 Serviço externo (SE). </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="act_empreg" type="t:choiceType">
																						<xs:annotation>
																							<xs:documentation>II - 5.1.4 Actividades exercidas pelo empregador (E). </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="act_trab" type="t:choiceType">
																						<xs:annotation>
																							<xs:documentation>II - 5.1.5 Actividades exercidas pelo trabalhador designado (TD). </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																				</xs:sequence>
																			</xs:complexType>
																		</xs:element>
																		<xs:element name="saude" minOccurs="0">
																			<xs:annotation>
																				<xs:documentation>II - 5.2 No domínio da saúde. </xs:documentation>
																			</xs:annotation>
																			<xs:complexType>
																				<xs:sequence>
																					<xs:element name="serv_internos" type="t:choiceType">
																						<xs:annotation>
																							<xs:documentation>II - 5.2.1 Serviço interno (SI). </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="serv_part" type="t:choiceType">
																						<xs:annotation>
																							<xs:documentation>II - 5.2.2 Serviço comum (SCP). </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="serv_ext" type="t:choiceType">
																						<xs:annotation>
																							<xs:documentation>II - 5.2.3 Serviço externo (E). </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="serv_saude" type="t:choiceType">
																						<xs:annotation>
																							<xs:documentation>II - 5.2.4 Serviço Nacional/Regional de Saúde (SNS/SRS). </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																				</xs:sequence>
																			</xs:complexType>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="compl" type="t:choiceType">
																<xs:annotation>
																	<xs:documentation>II - 6. Foram complementados os serviços especificados em 5.? </xs:documentation>
																</xs:annotation>
															</xs:element>
															<!-- III - PESSOAL DOS SERVIÇOS DE SEGURANÇA E SAÚDE NO TRABALHO. -->
															<!-- III - 1.1 Indique o número de técnicos em cada grupo profissional, que exerceram actividade efectiva na unidade local -->
															<xs:element name="n_medicos" type="t:num2Type" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.1.1 Médicos do trabalho. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="n_enfer" type="t:num2Type" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.1.2 Enfermeiros. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="n_tec_sup_sht" type="t:num2Type" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.1.3 Técnicos Superiores de SHT. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="n_tec_sht" type="t:num2Type" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.1.4 Técnicos de SHT. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="outro_pess" type="t:num2Type" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.1.5 Outro pessoal. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<xs:element name="medicos" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.2 Médico(s) do trabalho. </xs:documentation>
																</xs:annotation>
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="medico" minOccurs="0" maxOccurs="unbounded">
																			<xs:annotation>
																				<xs:documentation>Médico </xs:documentation>
																			</xs:annotation>
																			<xs:complexType>
																				<xs:sequence>
																					<xs:element name="nome" type="t:max70Type">
																						<xs:annotation>
																							<xs:documentation>III - 1.2.1 Nome do Médico do trabalho. </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="n_cedula" type="t:num5Type">
																						<xs:annotation>
																							<xs:documentation>III - 1.2.2 Nº da célula profissional. </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="n_horas_mes">
																						<xs:annotation>
																							<xs:documentation>III - 1.2.3 Nº de horas mensais de afectação. </xs:documentation>
																						</xs:annotation>
																						<xs:simpleType>
																							<xs:annotation>
																								<xs:documentation>HHH,MM (H - horas ; M - minutos) </xs:documentation>
																							</xs:annotation>
																							<xs:restriction base="xs:token">
																								<xs:pattern value="\d{1,3},\d{2}" />
																							</xs:restriction>
																						</xs:simpleType>
																					</xs:element>
																				</xs:sequence>
																			</xs:complexType>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<xs:element name="tec_shts" minOccurs="0">
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="tec_sht" minOccurs="0" maxOccurs="unbounded">
																			<xs:annotation>
																				<xs:documentation>III - 1.3 Técnico de Segurança e Higiene do Trabalho. </xs:documentation>
																			</xs:annotation>
																			<xs:complexType>
																				<xs:sequence>
																					<xs:element name="nome" type="t:max70Type">
																						<xs:annotation>
																							<xs:documentation>III - 1.3.1 Nome do técnico de Segurança e Higiene no Trabalho. </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																					<xs:element name="cap" type="t:capType">
																						<xs:annotation>
																							<xs:documentation>III - 1.3.2 Nº Certificado de aptidão Profissional (CAP) </xs:documentation>
																						</xs:annotation>
																					</xs:element>
																				</xs:sequence>
																			</xs:complexType>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
															<!-- III - 1.4 Director/Responsável dos Serviços -->
															<xs:element name="resp_segu" type="responsavelType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.4.1 Director/Responsável dos Serviços de Segurança. </xs:documentation>
																</xs:annotation>
																<!-- III - 1.4.1.1 NIF -->
																<!-- III - 1.4.1.2 Nome -->
															</xs:element>
															<xs:element name="resp_saud" type="responsavelType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.4.2 Director/Responsável dos Serviços de Saúde. </xs:documentation>
																</xs:annotation>
																<!-- III - 1.4.2.1 NIF -->
																<!-- III - 1.4.2.2 Nome -->
															</xs:element>
															<xs:element name="empregador" type="intervenienteType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.5 Empregador. </xs:documentation>
																</xs:annotation>
																<!-- III - 1.5.1 Nome -->
																<!-- III - 1.5.2 nº autorização -->
															</xs:element>
															<xs:element name="trab_designado" type="intervenienteType" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.6 Trabalhador Designado. </xs:documentation>
																</xs:annotation>
																<!-- III - 1.6.1 Nome -->
																<!-- III - 1.6.2 nº autorização -->
															</xs:element>
															<xs:element name="nome_repr" type="t:max70Type" minOccurs="0">
																<xs:annotation>
																	<xs:documentation>III - 1.8 Nome do Representante do empregador para o acompanhamento de identificação dos serviços comuns/partilhados ou externos. </xs:documentation>
																</xs:annotation>
															</xs:element>
															<!-- No caso de Serviços Externos, indicar denominação e número de identificação fiscal da(s) entidade(s) prestadora(s) -->
															<xs:element name="servicos_ext" minOccurs="0">
																<xs:complexType>
																	<xs:sequence>
																		<xs:element name="servicos_seg" minOccurs="0">
																			<xs:complexType>
																				<xs:sequence>
																					<xs:element name="servico_seg" type="servicoType" minOccurs="0" maxOccurs="unbounded">
																						<xs:annotation>
																							<xs:documentation>III - 2.1 Serviços de Segurança. </xs:documentation>
																						</xs:annotation>
																						<!-- III - 2.1.1 NIF -->
																						<!-- III - 2.1.3 Tipo -->
																					</xs:element>
																				</xs:sequence>
																			</xs:complexType>
																		</xs:element>
																		<xs:element name="servicos_saude" minOccurs="0">
																			<xs:complexType>
																				<xs:sequence>
																					<xs:element name="servico_saude" type="servicoType" minOccurs="0" maxOccurs="unbounded">
																						<xs:annotation>
																							<xs:documentation>III - 2.1 Serviços de Saúde. </xs:documentation>
																						</xs:annotation>
																						<!-- III - 2.2.1 NIF -->
																						<!-- III - 2.2.3 Tipo -->
																					</xs:element>
																				</xs:sequence>
																			</xs:complexType>
																		</xs:element>
																	</xs:sequence>
																</xs:complexType>
															</xs:element>
