<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:t="http://www.gep.msess.gov.pt/sguri/tipos_comuns"
           xmlns="http://www.gep.msess.gov.pt/sguri/ru/anexo_ips"
           targetNamespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_ips"
           elementFormDefault="qualified"
           version="1.0.14">
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/tipos_comuns" schemaLocation="tipos-comuns-1.3.14.xsd"/>
    <xs:element name="anexo_ips" type="anexo_ipsType">
        <xs:annotation>
            <xs:documentation>ANEXO F - INFORMAÇÃO SOBRE PRESTADORES DE SERVIÇO</xs:documentation>
        </xs:annotation>
    </xs:element>
    <xs:complexType name="anexo_ipsType">
        <xs:sequence>
            <xs:element name="nome_entidade" type="t:max70Type">
                <xs:annotation>
                    <xs:documentation>Nome ou designação social</xs:documentation>
                </xs:annotation>
            </xs:element>
            <!-- I - CONTRATANTE) -->
            <xs:element name="exist_prest_serv" type="t:choiceType">
                <xs:annotation>
                    <xs:documentation>I - 1. Existiram contratos de prestação de serviços em algum período do ano de
                        referência do relatório?
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="dados_ips" minOccurs="0">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="cae_31Dez" type="t:caeType">
                            <xs:annotation>
                                <xs:documentation>I - 2. Actividade económica principal (CAE) do contratante em 31 de
                                    Dezembro.
                                </xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="prestadores">
                            <xs:annotation>
                                <xs:documentation>II - CARACTERIZAÇÃO DOS PRESTADORES DE SERVIÇO</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="prestador" minOccurs="1" maxOccurs="unbounded">
                                        <xs:complexType>
                                            <xs:sequence>
                                                <xs:element name="nif" type="t:nifType">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 2. Número de Identificação Fiscal
                                                            (NIF).
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <!-- II - 3. Segurança Social (NISS) ou equiparado -->
                                                <xs:element name="ident_reg_apli">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 3.1. Identificação do Regime Aplicado.
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:simpleContent>
                                                            <xs:restriction base="t:codigoType">
                                                                <xs:attribute name="tbl" use="required"
                                                                              fixed="RU_REREAP_RDX" type="xs:string">
                                                                    <xs:annotation>
                                                                        <xs:documentation>Tabela Nº 56 - Regime de
                                                                            reforma aplicado - Anexo F.
                                                                        </xs:documentation>
                                                                    </xs:annotation>
                                                                </xs:attribute>
                                                            </xs:restriction>
                                                        </xs:simpleContent>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:element name="niss" type="t:nissWorkerType">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 3.2. Nº de identificação da segurança
                                                            social (NISS) ou equiparado.
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <xs:element name="nome">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 4. Nome ou designação social
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                    <xs:simpleType>
                                                        <xs:restriction base="xs:string">
                                                            <xs:maxLength value="70"/>
                                                            <xs:minLength value="3"/>
                                                        </xs:restriction>
                                                    </xs:simpleType>
                                                </xs:element>
                                                <xs:element name="tipo">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 5. Tipo</xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:simpleContent>
                                                            <xs:restriction base="t:codigoType">
                                                                <xs:attribute name="tbl" use="required"
                                                                              fixed="RU_TPREST" type="xs:string">
                                                                    <xs:annotation>
                                                                        <xs:documentation>TABELA Nº 54 - Tipo de
                                                                            prestador.
                                                                        </xs:documentation>
                                                                    </xs:annotation>
                                                                </xs:attribute>
                                                            </xs:restriction>
                                                        </xs:simpleContent>
                                                    </xs:complexType>
                                                </xs:element>
                                                <!--  II - 6. Actividade desenvolvida (CAE/CIRS) -->
                                                <xs:element name="tipo_activ">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 6.1. Tipo de código de actividade.
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:simpleContent>
                                                            <xs:restriction base="t:codigoType">
                                                                <xs:attribute name="tbl" use="required"
                                                                              fixed="RU_TACTIV" type="xs:string">
                                                                    <xs:annotation>
                                                                        <xs:documentation>TABELA Nº 57 - Tipo de código
                                                                            de actividade.
                                                                        </xs:documentation>
                                                                    </xs:annotation>
                                                                </xs:attribute>
                                                            </xs:restriction>
                                                        </xs:simpleContent>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:choice>
                                                    <xs:element name="cae" type="t:caeType">
                                                        <xs:annotation>
                                                            <xs:documentation>II - 6.2. Actividade desenvolvida (CAE).
                                                            </xs:documentation>
                                                        </xs:annotation>
                                                    </xs:element>
                                                    <xs:element name="cirs">
                                                        <xs:annotation>
                                                            <xs:documentation>II - 6.2. Actividade desenvolvida (CIRS)
                                                            </xs:documentation>
                                                        </xs:annotation>
                                                        <xs:complexType>
                                                            <xs:simpleContent>
                                                                <xs:restriction base="t:codigoType">
                                                                    <xs:attribute name="tbl" use="required"
                                                                                  fixed="RU_CIRS" type="xs:string">
                                                                        <xs:annotation>
                                                                            <xs:documentation>TABELA Nº 55 - Código do
                                                                                Imposto Sobre os Rendimentos de Pessoas
                                                                                Singulares (CIRS).
                                                                            </xs:documentation>
                                                                        </xs:annotation>
                                                                    </xs:attribute>
                                                                </xs:restriction>
                                                            </xs:simpleContent>
                                                        </xs:complexType>
                                                    </xs:element>
                                                </xs:choice>
                                                <xs:element name="prestacoes">
                                                    <xs:complexType>
                                                        <xs:sequence>
                                                            <xs:element name="prestacao" minOccurs="1"
                                                                        maxOccurs="unbounded">
                                                                <xs:annotation>
                                                                    <xs:documentation>Prestação</xs:documentation>
                                                                </xs:annotation>
                                                                <xs:complexType>
                                                                    <xs:sequence>
                                                                        <!--  Datas da prestação de serviços -->
                                                                        <xs:element name="data_inicio"
                                                                                    type="t:yearmonthType"
                                                                                    minOccurs="0">
                                                                            <xs:annotation>
                                                                                <xs:documentation>II - 8. Data do início
                                                                                    da prestação de serviço.
                                                                                </xs:documentation>
                                                                            </xs:annotation>
                                                                        </xs:element>
                                                                        <xs:element name="data_fim"
                                                                                    type="t:yearmonthType"
                                                                                    minOccurs="0">
                                                                            <xs:annotation>
                                                                                <xs:documentation>II - 9. Data do fim da
                                                                                    prestação de serviço.
                                                                                </xs:documentation>
                                                                            </xs:annotation>
                                                                        </xs:element>
                                                                        <xs:choice minOccurs="0">
                                                                            <xs:element name="num_horas"
                                                                                        type="t:num4Type">
                                                                                <xs:annotation>
                                                                                    <xs:documentation>II - 10. Número de
                                                                                        horas afectas à actividade.
                                                                                    </xs:documentation>
                                                                                </xs:annotation>
                                                                            </xs:element>
                                                                            <xs:element name="num_trab"
                                                                                        type="t:num5Type">
                                                                                <xs:annotation>
                                                                                    <xs:documentation>II - 11. Número de
                                                                                        trabalhadores ao serviço.
                                                                                    </xs:documentation>
                                                                                </xs:annotation>
                                                                            </xs:element>
                                                                        </xs:choice>
                                                                    </xs:sequence>
                                                                </xs:complexType>
                                                            </xs:element>
                                                        </xs:sequence>
                                                    </xs:complexType>
                                                </xs:element>
                                            </xs:sequence>
                                        </xs:complexType>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="XML_DATA" use="required" fixed="1.0.14" type="xs:string">
            <xs:annotation>
                <xs:documentation>Versão da estrutura XML</xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="ano" use="required" type="t:yearType">
            <xs:annotation>
                <xs:documentation>Ano de referência.</xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="entidade" use="required" type="xs:long">
            <xs:annotation>
                <xs:documentation>ID Entidade.</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
</xs:schema>