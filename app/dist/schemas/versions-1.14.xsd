<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns="http://www.gep.msess.gov.pt/sguri/versions"
           targetNamespace="http://www.gep.msess.gov.pt/sguri/versions"
           elementFormDefault="qualified"
           version="1.1">
    <xs:element name="versions" type="versionsType"/>
    <xs:complexType name="versionsType">
        <xs:sequence>
            <xs:element name="version" maxOccurs="unbounded" minOccurs="0">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="XML_ID" type="xs:string"/>
                        <xs:element name="XML_DESC" type="xs:string"/>
                        <xs:element name="XML_VERSION" type="xs:string"/>
                        <xs:element name="XML_AREA" type="xs:string"/>
                        <xs:element name="XML_LAST_CHG" type="xs:string"/>
                        <xs:element name="XML_LOGO_HASH" type="xs:string"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
            <xs:element name="ctrl" maxOccurs="1" minOccurs="0">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="CTRL_ID" type="xs:string"/>
                        <xs:element name="CTRL_VERSION" type="xs:string"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
</xs:schema>