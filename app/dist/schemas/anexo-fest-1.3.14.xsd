<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:t="http://www.gep.msess.gov.pt/sguri/tipos_comuns"
           xmlns="http://www.gep.msess.gov.pt/sguri/ru/anexo_fest"
           targetNamespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_fest"
           elementFormDefault="qualified"
           version="1.3.14">
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/tipos_comuns" schemaLocation="tipos-comuns-1.3.14.xsd"/>
    <xs:element name="anexo_fest" type="anexo_festType"/>
    <xs:complexType name="anexo_festType">
        <xs:sequence>
            <!-- I - ENTIDADE EMPREGADORA  -->
            <xs:element name="nome_entidade" type="t:max70Type">
                <xs:annotation>
                    <xs:documentation>I - Nome ou Designação social</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="exist_entradas_saidas" type="t:choiceType">
                <xs:annotation>
                    <xs:documentation>I - 1. Existiram entradas e/ou saídas durante o ano de referência do relatório?
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="dados_fest" minOccurs="0">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="cae_31Dez" type="t:caeType">
                            <xs:annotation>
                                <xs:documentation>I - 2. Actividade económica principal (CAE) da Entidade empregadora em
                                    31 de Dezembro
                                </xs:documentation>
                            </xs:annotation>
                        </xs:element>
                        <xs:element name="trabalhadores">
                            <xs:annotation>
                                <xs:documentation>II - TRABALHADORES.</xs:documentation>
                            </xs:annotation>
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="trabalhador" minOccurs="0" maxOccurs="unbounded">
                                        <xs:complexType>
                                            <xs:sequence>
                                                <!-- II - 2. Regime de reforma aplicado (de Segurança Social ou outro). -->
                                                <xs:element name="ident_reg_apli">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 2.1 Identificação do Regime Aplicado.
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:simpleContent>
                                                            <xs:restriction base="t:codigoType">
                                                                <xs:attribute name="tbl" use="required"
                                                                              fixed="RU_REREAP" type="xs:string">
                                                                    <xs:annotation>
                                                                        <xs:documentation>TABELA Nº 11 - Regime de
                                                                            Reforma Aplicado.
                                                                        </xs:documentation>
                                                                    </xs:annotation>
                                                                </xs:attribute>
                                                            </xs:restriction>
                                                        </xs:simpleContent>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:element name="niss" type="t:nissWorkerType">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 2.2 Número de Identificação da Segurança
                                                            Social ou equiparado (NISS).
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <xs:element name="nome" type="t:max70Type">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 3. Nome</xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <xs:element name="tipo_contrato">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 4. Tipo de contrato.</xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:simpleContent>
                                                            <xs:restriction base="t:codigoType">
                                                                <xs:attribute name="tbl" use="required"
                                                                              fixed="RU_TIPCON" type="xs:string">
                                                                    <xs:annotation>
                                                                        <xs:documentation>TABELA Nº 13 - Tipo de
                                                                            Contrato.
                                                                        </xs:documentation>
                                                                    </xs:annotation>
                                                                </xs:attribute>
                                                            </xs:restriction>
                                                        </xs:simpleContent>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:element name="entrada" minOccurs="0">
                                                    <xs:annotation>
                                                        <xs:documentation>Entrada na entidade empregadora
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:sequence>
                                                            <xs:element name="data" type="t:yearmonthType">
                                                                <xs:annotation>
                                                                    <xs:documentation>II - 5. Data (ano / mês)
                                                                    </xs:documentation>
                                                                </xs:annotation>
                                                            </xs:element>
                                                            <xs:element name="motivo" minOccurs="0">
                                                                <xs:annotation>
                                                                    <xs:documentation>II - 6. Motivo (a preencher só
                                                                        para Tipo de contrato a termo).
                                                                    </xs:documentation>
                                                                </xs:annotation>
                                                                <xs:complexType>
                                                                    <xs:simpleContent>
                                                                        <xs:restriction base="t:codigoType">
                                                                            <xs:attribute name="tbl" use="required"
                                                                                          fixed="RU_MEEE"
                                                                                          type="xs:string">
                                                                                <xs:annotation>
                                                                                    <xs:documentation>TABELA Nº 26 -
                                                                                        Motivo da Entrada na Entidade
                                                                                        Empregadora.
                                                                                    </xs:documentation>
                                                                                </xs:annotation>
                                                                            </xs:attribute>
                                                                        </xs:restriction>
                                                                    </xs:simpleContent>
                                                                </xs:complexType>
                                                            </xs:element>
                                                        </xs:sequence>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:element name="saida" minOccurs="0">
                                                    <xs:annotation>
                                                        <xs:documentation>Saída da entidade empregadora
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:sequence>
                                                            <xs:element name="data" type="t:yearmonthType">
                                                                <xs:annotation>
                                                                    <xs:documentation>II - 7. Data (ano / mês)
                                                                    </xs:documentation>
                                                                </xs:annotation>
                                                            </xs:element>
                                                            <xs:element name="motivo">
                                                                <xs:annotation>
                                                                    <xs:documentation>II - 8. Motivo.</xs:documentation>
                                                                </xs:annotation>
                                                                <xs:complexType>
                                                                    <xs:simpleContent>
                                                                        <xs:restriction base="t:codigoType">
                                                                            <xs:attribute name="tbl" use="required"
                                                                                          fixed="RU_MSEE"
                                                                                          type="xs:string">
                                                                                <xs:annotation>
                                                                                    <xs:documentation>TABELA Nº 27 -
                                                                                        Motivo da Saída da Entidade
                                                                                        Empregadora.
                                                                                    </xs:documentation>
                                                                                </xs:annotation>
                                                                            </xs:attribute>
                                                                        </xs:restriction>
                                                                    </xs:simpleContent>
                                                                </xs:complexType>
                                                            </xs:element>
                                                        </xs:sequence>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:element name="sexo" type="t:sexType">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 9. Sexo</xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <xs:element name="data_nasc" type="t:yearmonthType">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 10. Data de Nascimento(ano / mês)
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <xs:element name="nacionalidade" type="t:countryType">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 11. Nacionalidade.</xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <xs:element name="habil_lit" minOccurs="0">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 12. Habilitação literária.
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:simpleContent>
                                                            <xs:restriction base="t:codigoType">
                                                                <xs:attribute name="tbl" use="required"
                                                                              fixed="RU_HABLIT" type="xs:string">
                                                                    <xs:annotation>
                                                                        <xs:documentation>TABELA Nº 14 - Habilitações
                                                                            literárias.
                                                                        </xs:documentation>
                                                                    </xs:annotation>
                                                                </xs:attribute>
                                                            </xs:restriction>
                                                        </xs:simpleContent>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:element name="sit_prof">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 13. Situação na profissão (SP).
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:simpleContent>
                                                            <xs:restriction base="t:codigoType">
                                                                <xs:attribute name="tbl" use="required"
                                                                              fixed="RU_SITPROF" type="xs:string">
                                                                    <xs:annotation>
                                                                        <xs:documentation>TABELA Nº 15 - Situação na
                                                                            Profissão.
                                                                        </xs:documentation>
                                                                    </xs:annotation>
                                                                </xs:attribute>
                                                            </xs:restriction>
                                                        </xs:simpleContent>
                                                    </xs:complexType>
                                                </xs:element>
                                                <xs:element name="prof">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 14. Profissão.</xs:documentation>
                                                    </xs:annotation>
                                                    <xs:complexType>
                                                        <xs:simpleContent>
                                                            <xs:restriction base="t:codigoType">
                                                                <xs:attribute name="tbl" use="required" fixed="RU_CPP"
                                                                              type="xs:string">
                                                                    <xs:annotation>
                                                                        <xs:documentation>TABELA Nº 16 - Classificação
                                                                            Portuguesa de Profissões (CPP 2010).
                                                                        </xs:documentation>
                                                                    </xs:annotation>
                                                                </xs:attribute>
                                                            </xs:restriction>
                                                        </xs:simpleContent>
                                                    </xs:complexType>
                                                </xs:element>
                                                <!-- II - 15. Total de horas suplementares efectuadas no ano civil -->
                                                <xs:element name="h_1art227" type="t:num3Type">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 15. Nº.1 do Art. 227º da Lei n.º 7/2009
                                                            de 12 de Fevereiro
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                                <xs:element name="h_2art227" type="t:num3Type">
                                                    <xs:annotation>
                                                        <xs:documentation>II - 16. Nº.2 do Art. 227º da Lei n.º 7/2009
                                                            de 12 de Fevereiro
                                                        </xs:documentation>
                                                    </xs:annotation>
                                                </xs:element>
                                            </xs:sequence>
                                        </xs:complexType>
                                    </xs:element>
                                </xs:sequence>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="entidade" use="required" type="xs:long"/>
        <xs:attribute name="ano" use="required" type="t:yearType">
            <xs:annotation>
                <xs:documentation>Ano de referência</xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="XML_DATA" use="required" fixed="1.3.14" type="xs:string">
            <xs:annotation>
                <xs:documentation>Versão da estrutura XML.</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
</xs:schema>