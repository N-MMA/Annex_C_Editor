<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:z="http://www.gep.msess.gov.pt/sguri/ru/anexo_zero"
           xmlns:qp="http://www.gep.msess.gov.pt/sguri/ru/anexo_qp"
           xmlns:fest="http://www.gep.msess.gov.pt/sguri/ru/anexo_fest"
           xmlns:sst="http://www.gep.msess.gov.pt/sguri/ru/anexo_sst"
           xmlns:grv="http://www.gep.msess.gov.pt/sguri/ru/anexo_grv"
           xmlns:rfc="http://www.gep.msess.gov.pt/sguri/ru/anexo_rfc"
           xmlns:ips="http://www.gep.msess.gov.pt/sguri/ru/anexo_ips"
           xmlns:sul="http://www.gep.msess.gov.pt/sguri/sul"
           xmlns:t="http://www.gep.msess.gov.pt/sguri/tipos_comuns"
           xmlns="http://www.gep.msess.gov.pt/sguri/ru"
           targetNamespace="http://www.gep.msess.gov.pt/sguri/ru"
           elementFormDefault="qualified"
           version="3.2.14">
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_zero" schemaLocation="anexo-zero-1.3.14.xsd"/>
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_qp" schemaLocation="anexo-qp-1.3.14.xsd"/>
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_fest" schemaLocation="anexo-fest-1.3.14.xsd"/>
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_sst" schemaLocation="anexo-sst-2.3.14.xsd"/>
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_grv" schemaLocation="anexo-grv-3.2.14.xsd"/>
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_rfc" schemaLocation="anexo-rfc-1.2.14.xsd"/>
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/ru/anexo_ips" schemaLocation="anexo-ips-1.0.14.xsd"/>
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/sul" schemaLocation="sul-1.2.14.xsd"/>
    <xs:import namespace="http://www.gep.msess.gov.pt/sguri/tipos_comuns" schemaLocation="tipos-comuns-1.3.14.xsd"/>
    <xs:include schemaLocation="entity-data-1.2.14.xsd"/>
    <xs:element name="relatorio_unico" type="relatorio_unicoType"/>
    <xs:complexType name="relatorio_unicoType">
        <xs:sequence>
            <xs:element name="header" type="headerType"/>
            <xs:element name="body" type="bodyType"/>
        </xs:sequence>
        <xs:attribute name="XML_DATA" use="required" fixed="3.2.14" type="xs:string">
            <xs:annotation>
                <xs:documentation>Versão da estrutura XML.</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="headerType">
        <xs:sequence>
            <xs:element name="aplicacao" type="aplicacaoType"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="aplicacaoType">
        <xs:sequence>
            <xs:element name="nome" type="t:minType"/>
            <xs:element name="versao" type="t:minType"/>
            <xs:element name="empresa" type="t:minType"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="bodyType">
        <xs:sequence>
            <xs:element ref="entity_data" minOccurs="0"/>
            <xs:element name="anexos" type="anexosType"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="entity_dataType">
        <xs:sequence>
            <xs:element name="active_estabs" minOccurs="0">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="estabs" minOccurs="0" maxOccurs="unbounded">
                            <xs:complexType>
                                <xs:sequence>
                                    <xs:element name="estab" minOccurs="0" maxOccurs="unbounded">
                                        <xs:complexType>
                                            <xs:attribute name="hq" type="xs:boolean"/>
                                            <xs:attribute name="id" type="xs:long"/>
                                        </xs:complexType>
                                    </xs:element>
                                </xs:sequence>
                                <xs:attribute name="annex" use="required" type="xs:string"/>
                            </xs:complexType>
                        </xs:element>
                    </xs:sequence>
                    <xs:attribute name="year_ref" type="t:yearType"/>
                </xs:complexType>
            </xs:element>
            <xs:element ref="sul:entity"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="anexosType">
        <xs:sequence>
            <xs:element ref="z:anexo_zero" minOccurs="0"/>
            <xs:element ref="qp:anexo_qp" minOccurs="0"/>
            <xs:element ref="fest:anexo_fest" minOccurs="0"/>
            <xs:element ref="sst:anexo_sst" minOccurs="0"/>
            <xs:element ref="grv:anexo_grv" minOccurs="0"/>
            <xs:element ref="rfc:anexo_rfc" minOccurs="0"/>
            <xs:element ref="ips:anexo_ips" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
</xs:schema>